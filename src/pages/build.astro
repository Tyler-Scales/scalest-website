---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Build Your Talent" description="Develop AI skills inside your healthcare organization through certified Microsoft training, cohort-based programs, and hands-on workshops.">

  <!-- Page header -->
  <section class="page-hero">
    <div class="page-hero-inner page-hero-grid">
      <div class="hero-content">
        <div class="hero-badge">Build</div>
        <h1>Build Your Talent</h1>
        <p>Develop AI skills inside your healthcare organization through certified Microsoft training, cohort-based programs, and hands-on workshops. Your team walks away with skills they can use Monday morning.</p>
      </div>
      <div class="hero-image">
        <img src="/images/healthcare-tech.jpg" alt="Healthcare technology training" />
      </div>
    </div>
  </section>

  <!-- Placeholder -->
  <section class="section">
    <div class="section-inner section-center">
      <div class="section-header">
        <h2>Full Build services content coming soon.</h2>
        <p>In the meantime, reach out to learn how we can develop AI skills inside your organization.</p>
      </div>
      <a href="/contact" class="btn btn-primary">Get in touch <span class="arrow">&rarr;</span></a>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    padding: 5rem 1.5rem 3rem;
    background: var(--color-white);
  }

  .page-hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .page-hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-image img {
    width: 100%;
    height: 360px;
    object-fit: cover;
    border-radius: 20px;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-blue);
    background: rgba(15, 15, 189, 0.07);
    padding: 0.375rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
    letter-spacing: 0.01em;
  }

  .page-hero h1 {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--color-dark);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .page-hero p {
    font-size: 1.125rem;
    color: var(--color-gray-500);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 3.5rem 1.25rem 2.5rem;
    }

    .page-hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-image img {
      height: 240px;
    }

    .page-hero h1 {
      font-size: 2rem;
    }
  }
</style>
