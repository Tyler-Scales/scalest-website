---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../../content/pages/ambient-ai-training.json';
---

<BaseLayout
  title="Ambient AI Training"
  description="Hands-on training for Nuance DAX and Sunio by eClinicalWorks. We train your clinicians to use ambient AI documentation tools effectively from day one."
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="page-hero-inner">
      <div>
        <p class="hero-badge">Ambient AI Training</p>
        <h1>{data.heroTitle}<span class="gradient-text">{data.heroTitleGradient}</span></h1>
        <p class="hero-sub">{data.heroSubtitle}</p>
        <a href="https://outlook.office.com/owa/calendar/BooktimewithTylerWallace@scalestsolutions.com/bookings/s/sGNGp0yBEkSgbnIiVwCUOQ2" class="btn btn-primary btn-lg">Book a Discovery Call <span class="arrow">&rarr;</span></a>
      </div>
      <div class="hero-image">
        <img src="/images/Tyler%20Training%202.jpg" alt="Tyler Wallace delivering ambient AI training" />
      </div>
    </div>
  </section>

  <!-- Products -->
  {data.products?.items?.map((product, i) => (
    <section class={`section ${i % 2 === 0 ? 'section-alt' : ''}`}>
      <div class="section-inner">
        <div class={`split-row ${i % 2 === 1 ? 'reverse' : ''}`}>
          <div class="split-text">
            <p class="label-tag">{product.name}</p>
            <h2>{product.fullName}</h2>
            <p class="split-desc">{product.description}</p>
            <ul class="check-list">
              {product.highlights?.map((highlight, j) => (
                <li>
                  <svg class="check-icon" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill={j % 2 === 0 ? 'var(--color-peach)' : 'var(--color-mint)'}/><path d="M6 10.5l2.5 2.5 5.5-5.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <div>
                    <strong>{highlight}</strong>
                  </div>
                </li>
              ))}
            </ul>
          </div>
          <div class="split-image">
            <img src={`/images/${i === 0 ? 'healthcare-tech' : 'healthcare-team'}.jpg`} alt={product.name + ' training'} />
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Training Formats -->
  <section class="section section-alt">
    <div class="section-inner section-center">
      <p class="label-tag" style="text-align:center;">How We Train</p>
      <h2 class="section-title">{data.formats?.title}<span class="gradient-text">{data.formats?.titleGradient}</span></h2>
      <p class="section-subtitle">{data.formats?.subtitle}</p>
      <div class="format-grid">
        {data.formats?.items?.map((item) => (
          <div class="format-card">
            <p class="format-num">{item.number}</p>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section">
    <div class="section-inner section-center">
      <p class="label-tag" style="text-align:center;">Track Record</p>
      <h2 class="section-title">Proven <span class="gradient-text">Results</span></h2>
    </div>
    <div class="section-inner">
      <div class="card-grid cols-2">
        {data.stats?.map((stat) => (
          <div class="card" style="text-align:center;">
            <span class="card-metric">{stat.value}</span>
            <p>{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="section-inner section-center">
      <h2>{data.ctaTitle}</h2>
      <p>{data.ctaSubtitle}</p>
      <div class="cta-actions">
        <a href="https://outlook.office.com/owa/calendar/BooktimewithTylerWallace@scalestsolutions.com/bookings/s/sGNGp0yBEkSgbnIiVwCUOQ2" class="btn btn-white btn-lg">Book a Discovery Call <span class="arrow">&rarr;</span></a>
        <a href="mailto:hello@scalestreet.com" class="btn btn-outline-white btn-lg">Email Us</a>
      </div>
    </div>
    <div class="cta-deco cta-deco-1"></div>
    <div class="cta-deco cta-deco-2"></div>
  </section>

</BaseLayout>

<style>
  .format-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .format-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 15px;
    padding: 2rem;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .format-card:hover {
    box-shadow: 0 10px 40px rgba(11, 34, 57, 0.1);
    transform: translateY(-4px);
  }

  .format-num {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-blue);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .format-card h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.5rem;
  }

  .format-card p {
    font-size: 0.875rem;
    color: var(--color-gray-500);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .format-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
