---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../../content/pages/home.json';

const focusColors = [
  'var(--color-mint)',
  'var(--color-blue)',
  'var(--color-peach)',
];
---

<BaseLayout title="Healthcare AI Training">

  <!-- Homepage Structured Data -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Scale Street — Healthcare AI Training",
    "description": "Scale Street delivers healthcare AI training — from general AI literacy to Microsoft-certified courses and ambient AI implementation.",
    "url": "https://scalestreet.com",
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": [".hero-text", ".section-header"]
    },
    "mainEntity": {
      "@type": "ProfessionalService",
      "name": "Scale St. Solutions",
      "description": "Healthcare AI training firm based in Athens, Georgia. We deliver AI training through webinars, workshops, and coaching.",
      "url": "https://scalestreet.com"
    }
  })} />

  <!-- Hero -->
  <section class="hero" id="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <p class="hero-label">{data.heroLabel}</p>
        <h1>{data.heroTitle}<span class="gradient-text">{data.heroTitleGradient}</span><br/>they need.</h1>
        <p class="hero-sub">{data.heroSubtitle}</p>
        <div class="hero-actions">
          <a href="https://outlook.office.com/owa/calendar/BooktimewithTylerWallace@scalestsolutions.com/bookings/s/sGNGp0yBEkSgbnIiVwCUOQ2" class="btn btn-primary btn-lg">Book a Discovery Call <span class="arrow">&rarr;</span></a>
          <a href="/general-ai-training" class="btn btn-outline btn-lg">Explore Training</a>
        </div>
      </div>
      <div class="hero-image">
        <img src="/images/Tyler%20Training%201.jpg" alt="Tyler Wallace leading an AI training session" />
      </div>
    </div>
    <div class="hero-deco hero-deco-1"></div>
    <div class="hero-deco hero-deco-2"></div>
  </section>

  <!-- The Challenge -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="split-row reverse">
        <div class="split-image">
          <img src="/images/healthcare-team.jpg" alt="Community healthcare provider" />
        </div>
        <div class="split-text">
          <p class="label-tag">The Challenge</p>
          <h2>{data.challengeTitle}<span class="gradient-text">{data.challengeTitleGradient}</span></h2>
          <p class="split-desc">{data.challengeDescription}</p>
          <div class="stat-row">
            {data.challengeStats?.map((stat) => (
              <div class="stat-chip">
                <span class="stat-chip-value">{stat.value}</span>
                <span class="stat-chip-label">{stat.label}</span>
              </div>
            ))}
          </div>
          <p class="split-cta-text"><strong>{data.challengeBottomText}</strong></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Training Focus Areas -->
  {data.trainingFocuses?.map((focus, i) => (
    <section class={`section ${i % 2 === 0 ? '' : 'section-alt'}`}>
      <div class="section-inner">
        <div class={`split-row ${i % 2 === 1 ? 'reverse' : ''}`}>
          <div class="split-text">
            <p class="label-tag">{focus.tag}</p>
            <h2>{focus.title}<span class="gradient-text">{focus.titleGradient}</span></h2>
            <p class="split-desc">{focus.description}</p>
            <ul class="check-list">
              <li>
                <svg class="check-icon" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill={focusColors[i] || 'var(--color-blue)'}/><path d="M6 10.5l2.5 2.5 5.5-5.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <div>
                  <strong>{focus.checklistTitle}</strong>
                  <span>{focus.checklistDescription}</span>
                </div>
              </li>
            </ul>
            <a href={focus.link} class="btn btn-primary">Learn More <span class="arrow">&rarr;</span></a>
          </div>
          <div class="split-image">
            <img src={`/images/${i === 0 ? 'healthcare-tech' : i === 1 ? 'healthcare-team' : 'rural-hospital'}.jpg`} alt={focus.tag + ' training'} />
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Credentials -->
  <section class="section section-alt">
    <div class="section-inner section-center">
      <p class="label-tag" style="text-align:center;">Credentials</p>
      <h2 class="section-title">Built for Healthcare. <span class="gradient-text">Proven in the Field.</span></h2>
      <p class="section-subtitle">We don't just talk about healthcare AI &mdash; we train the people who use it.</p>
    </div>
    <div class="section-inner">
      <div class="card-grid">
        {data.credentials?.map((cred) => (
          <div class="card">
            <span class="card-metric">{cred.metric}</span>
            <h3>{cred.title}</h3>
            <p>{cred.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Partner Logos -->
  <section class="section-sm">
    <div class="section-inner section-center">
      <p class="partners-label">Trusted Partners</p>
      <div class="partner-row">
        {data.partners?.map((partner, i) => (
          <Fragment>
            {i > 0 && <span class="partner-dot"></span>}
            <span class="partner-name">{partner}</span>
          </Fragment>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="section-inner section-center">
      <h2>{data.ctaTitle}</h2>
      <p>{data.ctaSubtitle}</p>
      <div class="cta-actions">
        <a href="https://outlook.office.com/owa/calendar/BooktimewithTylerWallace@scalestsolutions.com/bookings/s/sGNGp0yBEkSgbnIiVwCUOQ2" class="btn btn-white btn-lg">Book a Discovery Call <span class="arrow">&rarr;</span></a>
        <a href="mailto:hello@scalestreet.com" class="btn btn-outline-white btn-lg">Email Us</a>
      </div>
    </div>
    <div class="cta-deco cta-deco-1"></div>
    <div class="cta-deco cta-deco-2"></div>
  </section>

</BaseLayout>

<style>
  /* ===== HOMEPAGE HERO ===== */
  .hero {
    padding: 6rem 1.5rem 4rem;
    background: var(--color-white);
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-label {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-blue);
    background: rgba(15, 15, 189, 0.08);
    padding: 0.35rem 0.9rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: 2.75rem;
    font-weight: 900;
    color: var(--color-dark);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
  }

  .hero-sub {
    font-size: 1.0625rem;
    color: var(--color-gray-500);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-image img {
    width: 100%;
    border-radius: 15px;
    box-shadow: 0 20px 60px rgba(15, 15, 189, 0.12);
  }

  .hero-deco {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-deco-1 {
    width: 300px;
    height: 300px;
    background: rgba(110, 219, 188, 0.08);
    top: -80px;
    right: -60px;
  }

  .hero-deco-2 {
    width: 200px;
    height: 200px;
    background: rgba(15, 15, 189, 0.05);
    bottom: -40px;
    left: -60px;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3.5rem 1.25rem 2.5rem;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero-sub {
      max-width: 100%;
    }

    .hero-image {
      order: -1;
    }

    .hero-deco {
      display: none;
    }
  }
</style>
