---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Healthcare AI Consulting" description="Scale Street helps FQHCs, rural hospitals, and health systems close the AI talent gap through certified Microsoft training and fractional AI specialists designed for community health.">

  <!-- Homepage Structured Data for AEO -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Scale Street — AI Talent for Healthcare",
    "description": "Scale Street helps FQHCs, rural hospitals, and health systems close the AI talent gap through certified Microsoft training and fractional AI specialists designed for community health.",
    "url": "https://scalestreet.com",
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": [".hero-content", ".section-header"]
    },
    "mainEntity": {
      "@type": "ProfessionalService",
      "name": "Scale St. Solutions",
      "description": "AI talent for healthcare. Certified Microsoft training and fractional AI specialists for FQHCs, rural hospitals, and health systems.",
      "url": "https://scalestreet.com"
    }
  })} />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <h1>AI Talent for Healthcare. Built or Borrowed.</h1>
        <p>Scale Street helps FQHCs, rural hospitals, and health systems close the AI talent gap through certified Microsoft training and fractional AI specialists designed for community health.</p>
        <div class="hero-actions">
          <a href="/build" class="btn btn-primary">Build Your Talent <span class="arrow">&rarr;</span></a>
          <a href="/borrow" class="btn btn-outline">Borrow Our Talent</a>
        </div>
      </div>
      <div class="hero-image">
        <img src="/images/Pic 1.jpeg" alt="Tyler Wallace presenting Worker Concerns data" />
      </div>
    </div>
  </section>

  <!-- Social Proof Strip -->
  <section class="section-sm trust-bar">
    <div class="section-inner">
      <div class="trust-items">
        <div class="trust-item">
          <span class="trust-number">Microsoft Certified</span>
          <span class="trust-label">Trainer</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-number">2,000+</span>
          <span class="trust-label">Healthcare Professionals Trained</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-number">50+</span>
          <span class="trust-label">Workshops Delivered</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-number">First AI Certification</span>
          <span class="trust-label">for Rural Health</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="section">
    <div class="section-inner problem-section">
      <div class="section-header">
        <h2>Healthcare has an AI talent problem.</h2>
      </div>
      <p class="problem-body">The problem isn't the technology. It's that no one has trained your people to use it, and you can't hire AI specialists at community health salaries. That's the gap Scale Street was built to close.</p>
    </div>
  </section>

  <!-- Two Paths Section -->
  <section class="section bg-light">
    <div class="section-inner section-center">
      <div class="paths-grid">
        <div class="path-card">
          <div class="path-accent blue"></div>
          <div class="path-body">
            <h3>Build Your Talent</h3>
            <p>Your people are capable. They just haven't been trained on the tools sitting right in front of them. Our Build services develop AI skills inside your organization through certified Microsoft training, cohort-based programs, and hands-on workshops. Your team walks away with skills they can use Monday morning. Not theory. Not slide decks.</p>
            <a href="/build" class="btn btn-primary">View Build Services <span class="arrow">&rarr;</span></a>
          </div>
        </div>
        <div class="path-card">
          <div class="path-accent green"></div>
          <div class="path-body">
            <h3>Borrow Our Talent</h3>
            <p>You need a Power BI dashboard built this quarter. A Power Automate workflow deployed next month. A Copilot rollout managed properly. But your IT team of two can't do it, and a full-time hire isn't in the budget. Borrow gives you fractional access to Microsoft-certified specialists, embedded with your team, on your schedule, at a scope that fits your organization.</p>
            <a href="/borrow" class="btn btn-primary">View Borrow Services <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Who We Serve Section -->
  <section class="section">
    <div class="section-inner">
      <div class="section-header">
        <h2>Who we serve</h2>
      </div>
      <div class="serve-grid">
        <div class="serve-card">
          <div class="serve-icon blue">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3>Federally Qualified Health Centers (FQHCs)</h3>
          <p>You serve the underserved, and your operating budget reflects it. We help FQHCs adopt AI using the Microsoft tools you already pay for, with training and talent scaled to your reality. We've sat on FQHC network boards. We understand UDS reporting, HRSA requirements, 340B complexity, and what it means to run a health center on thin margins.</p>
        </div>
        <div class="serve-card">
          <div class="serve-icon green">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>
          </div>
          <h3>Critical Access & Rural Hospitals</h3>
          <p>With 1-3 person IT teams, tight margins, and growing pressure to modernize, rural hospitals need AI help, not enterprise-priced consulting. Scale Street brings certified Microsoft training and fractional specialists who understand your workflows, your EHR constraints, and your staffing reality.</p>
        </div>
        <div class="serve-card">
          <div class="serve-icon mint">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Health Center Networks (PCAs & HCCNs)</h3>
          <p>Your member health centers face the same AI talent gap individually. Through your network, they can solve it together. Scale Street delivers training cohorts and shared fractional specialists across your members. One contract, one partner, consistent results across 5, 10, or 20 health centers.</p>
        </div>
        <div class="serve-card">
          <div class="serve-icon peach">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <h3>Health Systems & Hospitals</h3>
          <p>For larger organizations exploring Microsoft AI tools, Scale Street provides MCT-led training and deployment support for Copilot, Power BI, and Power Platform, tailored to clinical and operational workflows.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Work -->
  <section class="section bg-light">
    <div class="section-inner section-center">
      <div class="section-header">
        <h2>Featured work</h2>
      </div>
      <div class="projects-grid">
        <div class="project-card">
          <div class="project-accent blue"></div>
          <div class="project-card-body">
            <span class="project-stat">100+ Providers</span>
            <h3>Nuance DAX Rollout</h3>
            <p>Ambient AI documentation deployed across multi-site Emergency Departments.</p>
          </div>
        </div>
        <div class="project-card">
          <div class="project-accent green"></div>
          <div class="project-card-body">
            <span class="project-stat">FQHC AI Enablement</span>
            <h3>Healow Genie AI</h3>
            <p>eClinicalWorks AI installation and configuration for an FQHC.</p>
          </div>
        </div>
        <div class="project-card">
          <div class="project-accent mint"></div>
          <div class="project-card-body">
            <span class="project-stat">Copilot + Agents</span>
            <h3>M365 Copilot Deployment</h3>
            <p>Setup, optimization, security hardening, and AI agent deployment.</p>
          </div>
        </div>
        <div class="project-card">
          <div class="project-accent peach"></div>
          <div class="project-card-body">
            <span class="project-stat">2,000+ Trained</span>
            <h3>Training Excellence</h3>
            <p>50+ workshops consistently rated the best technical training participants have experienced.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RHTP Section -->
  <section class="section bg-blue">
    <div class="section-inner">
      <div class="rhtp-grid">
        <div class="rhtp-content">
          <h2>Change Is Coming. Is Your Team Ready?</h2>
          <p>The $50 billion Rural Health Transformation Program is bringing new technology, new workflows, and new expectations to healthcare organizations in all 50 states through 2030.</p>
          <p>New tools will be implemented. Existing systems will be reconfigured. Reporting requirements will shift. And your staff, the people already stretched thin, will be the ones expected to absorb it all.</p>
          <p>The organizations that thrive through this transition won't be the ones with the biggest budgets. They'll be the ones whose teams were trained and supported before the change hit.</p>
          <p>Scale Street helps you get your people ready now so when transformation arrives, your staff leads it instead of scrambling to survive it.</p>
          <a href="/contact" class="btn btn-white" style="margin-top: 1.5rem;">Start preparing your team <span class="arrow">&rarr;</span></a>
        </div>
        <div class="rhtp-visual">
          <img src="/images/rural-hospital.jpg" alt="Rural hospital building" class="rhtp-image" />
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section cta-section">
    <div class="section-inner section-center">
      <div class="section-header">
        <h2>Ready to close the AI talent gap?</h2>
        <p>Whether you want to build your team's AI skills over time or need fractional talent embedded tomorrow, let's start with a conversation. No pitch decks. No pressure. Just a clear look at where AI can make a real difference for your organization.</p>
      </div>
      <a href="/contact" class="btn btn-primary">Schedule a Conversation <span class="arrow">&rarr;</span></a>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 5rem 1.5rem 0;
    background: var(--color-white);
    overflow: hidden;
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero h1 {
    font-size: 2.75rem;
    font-weight: 900;
    line-height: 1.1;
    color: var(--color-dark);
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .hero p {
    font-size: 1.0625rem;
    color: var(--color-gray-500);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-image {
    position: relative;
  }

  .hero-image img {
    width: 100%;
    height: 480px;
    object-fit: cover;
    border-radius: 24px 24px 0 0;
  }

  /* Trust bar */
  .trust-bar {
    border-bottom: 1px solid var(--color-gray-200);
  }

  .trust-items {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .trust-number {
    font-size: 1rem;
    font-weight: 900;
    color: var(--color-dark);
  }

  .trust-label {
    font-size: 0.75rem;
    color: var(--color-gray-500);
    font-weight: 600;
  }

  .trust-divider {
    width: 1px;
    height: 40px;
    background: var(--color-gray-200);
  }

  /* Problem section */
  .problem-section {
    max-width: 780px;
  }

  .problem-section .section-header {
    margin-bottom: 1.5rem;
  }

  .problem-body {
    font-size: 1.0625rem;
    color: var(--color-gray-600);
    line-height: 1.8;
  }

  /* Two Paths */
  .bg-light {
    background: var(--color-gray-50);
  }

  .paths-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .path-card {
    display: flex;
    overflow: hidden;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 16px;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .path-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .path-accent {
    width: 6px;
    flex-shrink: 0;
  }

  .path-accent.blue { background: var(--color-blue); }
  .path-accent.green { background: var(--color-green); }

  .path-body {
    padding: 2rem;
  }

  .path-body h3 {
    font-size: 1.375rem;
    font-weight: 900;
    color: var(--color-dark);
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .path-body p {
    font-size: 0.9375rem;
    color: var(--color-gray-500);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  /* Who We Serve */
  .serve-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .serve-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 16px;
    padding: 2rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .serve-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .serve-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .serve-icon.blue { background: var(--color-blue); }
  .serve-icon.green { background: var(--color-green); }
  .serve-icon.mint { background: var(--color-blue-light); }
  .serve-icon.peach { background: var(--color-peach); }

  .serve-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.75rem;
  }

  .serve-card p {
    font-size: 0.9375rem;
    color: var(--color-gray-500);
    line-height: 1.7;
  }

  /* Featured Projects */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .project-card {
    display: flex;
    overflow: hidden;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 16px;
    transition: box-shadow 0.2s, transform 0.2s;
    text-align: left;
  }

  .project-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .project-accent {
    width: 6px;
    flex-shrink: 0;
  }

  .project-accent.blue { background: var(--color-blue); }
  .project-accent.green { background: var(--color-green); }
  .project-accent.mint { background: var(--color-blue-light); }
  .project-accent.peach { background: var(--color-peach); }

  .project-card-body {
    padding: 1.5rem;
  }

  .project-stat {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-500);
    margin-bottom: 0.5rem;
  }

  .project-card h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.375rem;
  }

  .project-card p {
    font-size: 0.875rem;
    color: var(--color-gray-500);
    line-height: 1.6;
  }

  /* RHTP Section */
  .bg-blue {
    background: var(--color-blue);
    color: var(--color-white);
  }

  .rhtp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .rhtp-content h2 {
    font-size: 2rem;
    font-weight: 900;
    color: var(--color-white);
    line-height: 1.2;
    margin-bottom: 1.25rem;
  }

  .rhtp-content p {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .rhtp-visual {
    display: flex;
    justify-content: center;
  }

  .rhtp-image {
    width: 100%;
    height: 420px;
    object-fit: cover;
    border-radius: 20px;
    border: 3px solid rgba(255, 255, 255, 0.15);
  }

  /* CTA */
  .cta-section {
    background: var(--color-gray-50);
    text-align: center;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 1.25rem 0;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero-image img {
      height: 300px;
      border-radius: 16px 16px 0 0;
    }

    .trust-divider {
      display: none;
    }

    .trust-items {
      gap: 1.5rem;
    }

    .paths-grid {
      grid-template-columns: 1fr;
    }

    .serve-grid {
      grid-template-columns: 1fr;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }

    .rhtp-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .rhtp-image {
      height: 280px;
    }
  }
</style>
