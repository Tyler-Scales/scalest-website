---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../../content/pages/microsoft-ai-training.json';
---

<BaseLayout
  title="Microsoft-Certified AI Training"
  description="Official Microsoft AI courses for healthcare organizations. AB-730, AB-900, and Copilot Builders training developed in partnership with Microsoft."
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="page-hero-inner">
      <div>
        <p class="hero-badge">Microsoft AI Training</p>
        <h1>{data.heroTitle}<span class="gradient-text">{data.heroTitleGradient}</span></h1>
        <p class="hero-sub">{data.heroSubtitle}</p>
        <a href="https://outlook.office.com/owa/calendar/BooktimewithTylerWallace@scalestsolutions.com/bookings/s/sGNGp0yBEkSgbnIiVwCUOQ2" class="btn btn-primary btn-lg">Book a Discovery Call <span class="arrow">&rarr;</span></a>
      </div>
      <div class="hero-image">
        <img src="/images/Tyler%20Training%202.jpg" alt="Tyler Wallace delivering Microsoft AI training" />
      </div>
    </div>
  </section>

  <!-- Courses -->
  <section class="section section-alt">
    <div class="section-inner section-center">
      <p class="label-tag" style="text-align:center;">Courses</p>
      <h2 class="section-title">{data.courses?.title}<span class="gradient-text">{data.courses?.titleGradient}</span></h2>
      <p class="section-subtitle">{data.courses?.subtitle}</p>
    </div>
    <div class="section-inner">
      <div class="course-grid">
        {data.courses?.items?.map((course) => (
          <div class="course-card">
            <span class="course-code">{course.code}</span>
            <h3>{course.title}</h3>
            <p class="course-desc">{course.description}</p>
            <p class="course-audience"><strong>For:</strong> {course.audience}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Training Formats -->
  <section class="section">
    <div class="section-inner section-center">
      <p class="label-tag" style="text-align:center;">How We Train</p>
      <h2 class="section-title">{data.formats?.title}<span class="gradient-text">{data.formats?.titleGradient}</span></h2>
      <p class="section-subtitle">{data.formats?.subtitle}</p>
      <div class="format-grid">
        {data.formats?.items?.map((item) => (
          <div class="format-card">
            <p class="format-num">{item.number}</p>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Microsoft Partnership -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="split-row">
        <div class="split-text">
          <p class="label-tag">Partnership</p>
          <h2>{data.partnership?.title}<span class="gradient-text">{data.partnership?.titleGradient}</span></h2>
          <p class="split-desc">{data.partnership?.description}</p>
          <ul class="check-list">
            {data.partnership?.highlights?.map((highlight, i) => (
              <li>
                <svg class="check-icon" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill={i % 2 === 0 ? 'var(--color-blue)' : 'var(--color-mint)'}/><path d="M6 10.5l2.5 2.5 5.5-5.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <div>
                  <strong>{highlight}</strong>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div class="split-image mct-badge-wrap">
          <img src="/images/MCTBadgeMark.svg" alt="Microsoft Certified Trainer" class="mct-badge" />
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="testimonial-section">
    <div class="section-inner">
      <div class="testimonial-card">
        <p class="testimonial-quote">Tyler is an excellent instructor — he was very knowledgeable, covered material at a good pace, and had great hands-on activities to keep us engaged and learning. One of the best instructors I've ever had for a training course.</p>
        <p class="testimonial-attr">Training Participant</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="section-inner section-center">
      <h2>{data.ctaTitle}</h2>
      <p>{data.ctaSubtitle}</p>
      <div class="cta-actions">
        <a href="https://outlook.office.com/owa/calendar/BooktimewithTylerWallace@scalestsolutions.com/bookings/s/sGNGp0yBEkSgbnIiVwCUOQ2" class="btn btn-white btn-lg">Book a Discovery Call <span class="arrow">&rarr;</span></a>
        <a href="mailto:hello@scalestreet.com" class="btn btn-outline-white btn-lg">Email Us</a>
      </div>
    </div>
    <div class="cta-deco cta-deco-1"></div>
    <div class="cta-deco cta-deco-2"></div>
  </section>

</BaseLayout>

<style>
  .mct-badge-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-white);
    box-shadow: none;
    border: none;
  }

  .mct-badge {
    max-width: 280px;
    height: auto;
    border-radius: 0;
    box-shadow: none;
  }

  .course-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .course-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 15px;
    padding: 2rem;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .course-card:hover {
    box-shadow: 0 10px 40px rgba(11, 34, 57, 0.1);
    transform: translateY(-4px);
  }

  .course-code {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-blue);
    background: rgba(15, 15, 189, 0.08);
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }

  .course-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.75rem;
  }

  .course-desc {
    font-size: 0.875rem;
    color: var(--color-gray-500);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .course-audience {
    font-size: 0.8125rem;
    color: var(--color-gray-500);
    border-top: 1px solid var(--color-gray-200);
    padding-top: 0.75rem;
  }

  .course-audience strong {
    color: var(--color-dark);
  }

  .format-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .format-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 15px;
    padding: 2rem;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .format-card:hover {
    box-shadow: 0 10px 40px rgba(11, 34, 57, 0.1);
    transform: translateY(-4px);
  }

  .format-num {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-blue);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .format-card h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.5rem;
  }

  .format-card p {
    font-size: 0.875rem;
    color: var(--color-gray-500);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .course-grid {
      grid-template-columns: 1fr;
    }

    .format-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
