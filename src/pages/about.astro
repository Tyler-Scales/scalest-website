---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../../content/pages/about.json';

const valueIcons = {
  blue: { color: 'var(--color-blue)', svg: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>' },
  green: { color: 'var(--color-green)', svg: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>' },
  peach: { color: 'var(--color-peach)', svg: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
};

const whoColors = ['var(--color-blue)', 'var(--color-mint)', 'var(--color-green)'];
---

<BaseLayout
  title="About Us"
  description="Scale Street is a healthcare AI training company based in Athens, Georgia, led by Tyler S. Wallace, Ph.D. We deliver AI training through webinars, workshops, and coaching."
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="page-hero-inner">
      <div>
        <p class="hero-badge">About Us</p>
        <h1>{data.heroTitle}<span class="gradient-text">{data.heroTitleGradient}</span></h1>
        <p class="hero-sub">{data.heroSubtitle}</p>
      </div>
      <div class="hero-image">
        <img src="/images/training-room.jpg" alt="AI training classroom" />
      </div>
    </div>
  </section>

  <!-- Our Story -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="split-row">
        <div class="split-text">
          <p class="label-tag">Our Story</p>
          <h2>{data.story?.title}<span class="gradient-text">{data.story?.titleGradient}</span></h2>
          {data.story?.paragraphs?.map((p) => (
            <p class="split-desc">{p}</p>
          ))}
        </div>
        <div class="split-image">
          <img src="/images/training-room.jpg" alt="Healthcare AI training session" />
        </div>
      </div>
    </div>
  </section>

  <!-- Tyler Bio -->
  <section class="section">
    <div class="section-inner">
      <div class="split-row reverse">
        <div class="split-image">
          <div class="bio-card">
            <div class="bio-avatar">
              <img src="/images/Tyler%20Headshot.jpg" alt={data.leadership?.name} />
            </div>
            <h3>{data.leadership?.name}</h3>
            <p class="bio-role">{data.leadership?.role}</p>
            <p class="bio-desc">{data.leadership?.shortBio}</p>
            <a href="https://linkedin.com/in/tylerwallace" target="_blank" rel="noopener" class="bio-linkedin">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          </div>
        </div>
        <div class="split-text">
          <p class="label-tag">Leadership</p>
          <h2>{data.leadership?.sectionTitle}<span class="gradient-text">{data.leadership?.sectionTitleGradient}</span></h2>
          {data.leadership?.paragraphs?.map((p) => (
            <p class="split-desc">{p}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section section-alt">
    <div class="section-inner section-center">
      <p class="label-tag" style="text-align:center;">What Drives Us</p>
      <h2 class="section-title">Our <span class="gradient-text">Values</span></h2>
    </div>
    <div class="section-inner">
      <div class="card-grid cols-3">
        {data.values?.map((value) => {
          const icon = valueIcons[value.color] || valueIcons.blue;
          return (
            <div class="card" style="text-align:center;">
              <div class={`value-icon ${value.color}`} style="margin-left:auto;margin-right:auto;">
                <svg viewBox="0 0 24 24" fill="none" stroke={icon.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icon.svg} />
              </div>
              <h3>{value.title}</h3>
              <p>{value.description}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Approach -->
  <section class="section bg-blue">
    <div class="section-inner section-center">
      <p class="label-tag" style="text-align:center; background: rgba(255,255,255,0.15); color: var(--color-white);">Our Approach</p>
      <h2 class="section-title" style="color: var(--color-white);">{data.approach?.title}</h2>
      <p class="section-subtitle" style="color: rgba(255,255,255,0.7);">{data.approach?.subtitle}</p>
      <div class="approach-grid">
        {data.approach?.steps?.map((step) => (
          <div class="approach-item">
            <p class="approach-num">{step.number}</p>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who We Work With -->
  <section class="section">
    <div class="section-inner">
      <div class="split-row">
        <div class="split-text">
          <p class="label-tag">Who We Work With</p>
          <h2>{data.whoWeWorkWith?.title}<span class="gradient-text">{data.whoWeWorkWith?.titleGradient}</span></h2>
          <p class="split-desc">{data.whoWeWorkWith?.description}</p>
          <ul class="check-list">
            {data.whoWeWorkWith?.items?.map((item, i) => (
              <li>
                <svg class="check-icon" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill={whoColors[i] || 'var(--color-blue)'}/><path d="M6 10.5l2.5 2.5 5.5-5.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <div>
                  <strong>{item.title}</strong>
                  <span>{item.description}</span>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div class="split-image">
          <img src="/images/ambient.jpg" alt="Ambient AI documentation training" />
        </div>
      </div>
    </div>
  </section>

  <!-- Client Logos -->
  <section class="section-sm">
    <div class="section-inner section-center">
      <p class="partners-label">Organizations We've Trained</p>
      <div class="logo-grid">
        <img src="/images/logos/piedmont-healthcare.png" alt="Piedmont Healthcare" />
        <img src="/images/logos/bon-secours-mercy-health.png" alt="Bon Secours Mercy Health" />
        <img src="/images/logos/scp-health.png" alt="SCP Health" />
        <img src="/images/logos/medlink-georgia.png" alt="MedLink Georgia" />
        <img src="/images/logos/elbert-memorial.png" alt="Elbert Memorial Hospital" />
        <img src="/images/logos/georgia-primary-care.png" alt="Georgia Primary Care Association" />
        <img src="/images/logos/georgia-nurses-association.png" alt="Georgia Nurses Association" />
        <img src="/images/logos/hope-for-georgia-moms.png" alt="Hope for Georgia Moms" />
        <img src="/images/logos/uga.png" alt="University of Georgia" />
        <img src="/images/logos/athens-tech.png" alt="Athens Technical College" />
        <img src="/images/logos/fda.png" alt="FDA" />
        <img src="/images/logos/usaid.jpg" alt="USAID" />
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonial-section section-alt">
    <div class="section-inner">
      <div class="testimonial-card">
        <p class="testimonial-quote">Tyler did a fantastic job in all areas of the training. It was fun and provided excellent content that significantly advances my knowledge of AI. I strongly encourage other learners to take his courses.</p>
        <p class="testimonial-attr">Training Participant</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="section-inner section-center">
      <h2>{data.ctaTitle}</h2>
      <p>{data.ctaSubtitle}</p>
      <div class="cta-actions">
        <a href="/courses" class="btn btn-white btn-lg">Enroll in a Course <span class="arrow">&rarr;</span></a>
        <a href="https://outlook.office.com/owa/calendar/BooktimewithTylerWallace@scalestsolutions.com/bookings/s/sGNGp0yBEkSgbnIiVwCUOQ2" class="btn btn-outline-white btn-lg">Bring Us On Site <span class="arrow">&rarr;</span></a>
      </div>
    </div>
    <div class="cta-deco cta-deco-1"></div>
    <div class="cta-deco cta-deco-2"></div>
  </section>

</BaseLayout>

<style>
  .bio-linkedin {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.75rem;
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .bio-linkedin:hover {
    color: var(--color-dark);
  }

  .logo-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 2rem 3rem;
    align-items: center;
    justify-items: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .logo-grid img {
    max-height: 50px;
    max-width: 140px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.7;
    transition: filter 0.3s, opacity 0.3s;
  }

  .logo-grid img:hover {
    filter: grayscale(0%);
    opacity: 1;
  }

  .partners-label {
    text-align: center;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gray-400);
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .logo-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem 2rem;
    }
  }

  @media (max-width: 480px) {
    .logo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
