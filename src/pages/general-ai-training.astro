---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../../content/pages/general-ai-training.json';

const whoColors = ['var(--color-blue)', 'var(--color-mint)', 'var(--color-green)'];
---

<BaseLayout
  title="General AI Training"
  description="Build AI fluency across your healthcare organization. Webinars, workshops, and coaching designed for leadership, clinical teams, and administrative staff."
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="page-hero-inner">
      <div>
        <p class="hero-badge">General AI Training</p>
        <h1>{data.heroTitle}<span class="gradient-text">{data.heroTitleGradient}</span></h1>
        <p class="hero-sub">{data.heroSubtitle}</p>
        <a href="https://outlook.office.com/owa/calendar/BooktimewithTylerWallace@scalestsolutions.com/bookings/s/sGNGp0yBEkSgbnIiVwCUOQ2" class="btn btn-primary btn-lg">Book a Discovery Call <span class="arrow">&rarr;</span></a>
      </div>
      <div class="hero-image">
        <img src="/images/Tyler%20Training%202.jpg" alt="Tyler Wallace delivering AI training" />
      </div>
    </div>
  </section>

  <!-- Training Formats -->
  <section class="section section-alt">
    <div class="section-inner section-center">
      <p class="label-tag" style="text-align:center;">How We Train</p>
      <h2 class="section-title">{data.formats?.title}<span class="gradient-text">{data.formats?.titleGradient}</span></h2>
      <p class="section-subtitle">{data.formats?.subtitle}</p>
      <div class="approach-grid">
        {data.formats?.items?.map((item) => (
          <div class="format-card">
            <p class="format-num">{item.number}</p>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Topics -->
  <section class="section">
    <div class="section-inner section-center">
      <p class="label-tag" style="text-align:center;">Curriculum</p>
      <h2 class="section-title">{data.topics?.title}<span class="gradient-text">{data.topics?.titleGradient}</span></h2>
    </div>
    <div class="section-inner">
      <div class="card-grid cols-2">
        {data.topics?.items?.map((topic) => (
          <div class="card">
            <h3>{topic.title}</h3>
            <p>{topic.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="split-row">
        <div class="split-text">
          <p class="label-tag">Audience</p>
          <h2>{data.whoItsFor?.title}<span class="gradient-text">{data.whoItsFor?.titleGradient}</span></h2>
          <p class="split-desc">{data.whoItsFor?.description}</p>
          <ul class="check-list">
            {data.whoItsFor?.items?.map((item, i) => (
              <li>
                <svg class="check-icon" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill={whoColors[i] || 'var(--color-blue)'}/><path d="M6 10.5l2.5 2.5 5.5-5.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <div>
                  <strong>{item.title}</strong>
                  <span>{item.description}</span>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div class="split-image">
          <img src="/images/healthcare-team.jpg" alt="Healthcare professionals" />
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section">
    <div class="section-inner section-center">
      <p class="label-tag" style="text-align:center;">Track Record</p>
      <h2 class="section-title">Proven <span class="gradient-text">Results</span></h2>
    </div>
    <div class="section-inner">
      <div class="card-grid cols-3">
        {data.stats?.map((stat) => (
          <div class="card" style="text-align:center;">
            <span class="card-metric">{stat.value}</span>
            <p>{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="testimonial-section section-alt">
    <div class="section-inner">
      <div class="testimonial-card">
        <p class="testimonial-quote">Truly one of the best instructors I have had in a long time. Very knowledgeable and engaging and provided great information and guidance on utilizing generative AI.</p>
        <p class="testimonial-attr">Training Participant</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="section-inner section-center">
      <h2>{data.ctaTitle}</h2>
      <p>{data.ctaSubtitle}</p>
      <div class="cta-actions">
        <a href="/courses" class="btn btn-white btn-lg">Enroll in a Course <span class="arrow">&rarr;</span></a>
        <a href="https://outlook.office.com/owa/calendar/BooktimewithTylerWallace@scalestsolutions.com/bookings/s/sGNGp0yBEkSgbnIiVwCUOQ2" class="btn btn-outline-white btn-lg">Bring Us On Site <span class="arrow">&rarr;</span></a>
      </div>
    </div>
    <div class="cta-deco cta-deco-1"></div>
    <div class="cta-deco cta-deco-2"></div>
  </section>

</BaseLayout>

<style>
  .format-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 15px;
    padding: 2rem;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .format-card:hover {
    box-shadow: 0 10px 40px rgba(11, 34, 57, 0.1);
    transform: translateY(-4px);
  }

  .format-num {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-blue);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .format-card h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.5rem;
  }

  .format-card p {
    font-size: 0.875rem;
    color: var(--color-gray-500);
    line-height: 1.6;
  }

  .approach-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .approach-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
