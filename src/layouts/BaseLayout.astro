---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "Scale Street delivers healthcare AI training — from general AI literacy to Microsoft-certified courses and ambient AI implementation. Give your team the skills they need.", ogImage = "/images/hero-healthcare.jpg" } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
const isHomepage = Astro.url.pathname === '/' || Astro.url.pathname === '';
const fullTitle = isHomepage ? "Scale Street — Healthcare AI Training" : `${title} | Scale Street`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Page title -->
    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:site_name" content="Scale Street" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />

    <!-- Additional SEO -->
    <meta name="author" content="Scale St. Solutions" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0f0fbd" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;600;700;900&display=swap" rel="stylesheet" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Scale St. Solutions",
      "alternateName": "Scale Street",
      "url": "https://scalestreet.com",
      "logo": "https://scalestreet.com/logo.avif",
      "description": "Scale Street delivers healthcare AI training — from general AI literacy to Microsoft-certified courses and ambient AI implementation. Give your team the skills they need.",
      "email": "hello@scalestreet.com",
      "telephone": "+1-706-206-2530",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Athens",
        "addressRegion": "GA",
        "addressCountry": "US"
      },
      "areaServed": [
        {
          "@type": "Place",
          "name": "Southeastern United States"
        },
        {
          "@type": "Country",
          "name": "United States"
        }
      ],
      "founder": {
        "@type": "Person",
        "name": "Tyler S. Wallace",
        "honorificSuffix": "Ph.D.",
        "jobTitle": "Principal Consultant",
        "worksFor": {
          "@type": "Organization",
          "name": "Scale St. Solutions"
        }
      },
      "priceRange": "$$",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Healthcare AI Training Programs",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "General AI Training",
              "description": "AI literacy and adoption training for healthcare teams through webinars, workshops, and coaching.",
              "url": "https://scalestreet.com/general-ai-training"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Microsoft-Certified AI Training",
              "description": "Microsoft-certified AI courses including AB-730, AB-900, and Copilot Builders for healthcare organizations.",
              "url": "https://scalestreet.com/microsoft-ai-training"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Ambient AI Training",
              "description": "Training for ambient clinical documentation tools including Nuance DAX and Sunio/eClinicalWorks.",
              "url": "https://scalestreet.com/ambient-ai-training"
            }
          }
        ]
      },
      "serviceType": [
        "General AI Training",
        "Microsoft-Certified AI Training",
        "Ambient AI Training"
      ],
      "knowsAbout": [
        "Healthcare AI Training",
        "AI Literacy",
        "Microsoft AI Certification",
        "AB-730",
        "AB-900",
        "Microsoft 365 Copilot",
        "Microsoft Nuance DAX",
        "Ambient Clinical Documentation",
        "eClinicalWorks Sunio",
        "AI Workforce Development"
      ],
      "sameAs": [
        "https://github.com/Tyler-Scales"
      ]
    })} />

    <!-- Page-specific head content -->
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav-container">
        <a href="/" class="logo"><img src="/logo.avif" alt="Scale Street" class="logo-img" /></a>
        <button class="mobile-toggle" aria-label="Toggle navigation" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <ul class="nav-links">
          <li class="nav-dropdown">
            <button class="nav-dropdown-toggle" aria-expanded="false">Training <svg class="dropdown-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
            <ul class="nav-dropdown-menu">
              <li><a href="/general-ai-training">General AI</a></li>
              <li><a href="/microsoft-ai-training">Microsoft</a></li>
              <li><a href="/ambient-ai-training">Providers</a></li>
            </ul>
          </li>
          <li><a href="/courses">Upcoming Courses</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="https://outlook.office.com/owa/calendar/BooktimewithTylerWallace@scalestsolutions.com/bookings/s/sGNGp0yBEkSgbnIiVwCUOQ2" class="btn btn-primary btn-sm nav-cta">Book a Call</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-container">
        <div class="footer-brand">
          <img src="/logo.avif" alt="Scale Street" class="footer-logo-img" />
          <p>Healthcare AI training that gives your team the skills to adopt AI on their terms.</p>
        </div>
        <div class="footer-links">
          <div class="footer-col">
            <h4>Training</h4>
            <ul>
              <li><a href="/general-ai-training">General AI Training</a></li>
              <li><a href="/microsoft-ai-training">Microsoft Training</a></li>
              <li><a href="/ambient-ai-training">Provider Training</a></li>
              <li><a href="/courses">Upcoming Courses</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Company</h4>
            <ul>
              <li><a href="/about">About Us</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Connect</h4>
            <ul>
              <li><a href="mailto:hello@scalestreet.com">hello@scalestreet.com</a></li>
              <li><a href="https://linkedin.com/company/scalestreet" target="_blank" rel="noopener">LinkedIn</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Scale Street. All rights reserved.</p>
      </div>
    </footer>

    <!-- Back to Top Button -->
    <button class="back-to-top" aria-label="Back to top" id="backToTop">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 16V4m0 0L4 10m6-6l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>

    <script>
      // Mobile menu toggle
      const toggle = document.querySelector('.mobile-toggle');
      const navLinks = document.querySelector('.nav-links');
      toggle?.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        navLinks?.classList.toggle('open');
      });

      // Dropdown toggle
      const dropdown = document.querySelector('.nav-dropdown');
      const dropdownToggle = document.querySelector('.nav-dropdown-toggle');
      dropdownToggle?.addEventListener('click', (e) => {
        e.stopPropagation();
        dropdown?.classList.toggle('open');
        const expanded = dropdownToggle.getAttribute('aria-expanded') === 'true';
        dropdownToggle.setAttribute('aria-expanded', String(!expanded));
      });

      // Close dropdown when clicking outside
      document.addEventListener('click', (e) => {
        if (!dropdown?.contains(e.target as Node)) {
          dropdown?.classList.remove('open');
          dropdownToggle?.setAttribute('aria-expanded', 'false');
        }
      });

      // Close mobile menu on link click
      navLinks?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          navLinks.classList.remove('open');
          dropdown?.classList.remove('open');
          toggle?.setAttribute('aria-expanded', 'false');
        });
      });

      // Active page highlighting
      const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
      document.querySelectorAll('.nav-links a:not(.nav-cta)').forEach(a => {
        const href = (a.getAttribute('href') || '').replace(/\/$/, '') || '/';
        if (href === currentPath) {
          a.classList.add('active');
          // If active link is inside dropdown, mark parent
          const parentDropdown = a.closest('.nav-dropdown');
          if (parentDropdown) {
            parentDropdown.classList.add('has-active');
          }
        }
      });

      // Scroll-reveal animations
      const revealElements = document.querySelectorAll('.section, .section-sm, .section-alt, .page-hero, .testimonial-section, .cta-section');
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      revealElements.forEach(el => {
        el.classList.add('reveal');
        revealObserver.observe(el);
      });

      // Back to top button
      const backToTop = document.getElementById('backToTop');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 600) {
          backToTop?.classList.add('visible');
        } else {
          backToTop?.classList.remove('visible');
        }
      });
      backToTop?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      // Lazy loading for below-fold images
      document.querySelectorAll('img').forEach((img, i) => {
        if (i > 0) img.setAttribute('loading', 'lazy');
      });
    </script>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --color-blue: #0f0fbd;
    --color-blue-light: #4581ff;
    --color-dark: #333132;
    --color-mint: #6edbbc;
    --color-green: #095c44;
    --color-peach: #ff9563;
    --color-brown: #993a0e;
    --color-bg: #fafbfc;
    --color-white: #ffffff;
    --color-gray-50: #f8fafc;
    --color-gray-100: #f1f5f9;
    --color-gray-200: #e2e8f0;
    --color-gray-300: #cbd5e1;
    --color-gray-500: #70706e;
    --color-gray-600: #555555;
    --color-gray-700: #444444;
    --color-gray-800: #333132;
    --color-gray-900: #1a1a1a;
    --color-gray-light: #d1d1d4;
    --font-sans: 'Source Sans 3', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --max-width: 1120px;
    --header-height: 72px;
  }

  html {
    font-family: var(--font-sans);
    font-size: 20px;
    color: var(--color-gray-800);
    background: var(--color-bg);
    scroll-behavior: smooth;
    scroll-padding-top: var(--header-height);
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    line-height: 1.6;
  }

  main {
    flex: 1;
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul {
    list-style: none;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Section utilities */
  .section {
    padding: 5rem 1.5rem;
  }

  .section-sm {
    padding: 3rem 1.5rem;
  }

  .section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-header {
    max-width: 640px;
    margin-bottom: 3rem;
  }

  .section-header h2 {
    font-size: 2.25rem;
    font-weight: 900;
    color: var(--color-gray-900);
    margin-bottom: 1rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .section-header p {
    font-size: 1.125rem;
    color: var(--color-gray-500);
    line-height: 1.7;
  }

  .section-center .section-header {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .section-alt {
    background: var(--color-gray-50);
  }

  /* Button */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: 100px;
    font-weight: 700;
    font-size: 0.9375rem;
    transition: all 0.2s ease;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
  }

  .btn-primary {
    background: var(--color-blue);
    color: var(--color-white);
  }

  .btn-primary:hover {
    background: var(--color-blue-light);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-blue);
    border: 2px solid var(--color-blue);
  }

  .btn-outline:hover {
    background: var(--color-blue);
    color: var(--color-white);
  }

  .btn-white {
    background: var(--color-white);
    color: var(--color-dark);
  }

  .btn-white:hover {
    background: var(--color-gray-100);
  }

  .btn-sm {
    padding: 0.5rem 1.25rem;
    font-size: 0.8125rem;
  }

  .btn-lg {
    padding: 0.875rem 2rem;
    font-size: 1rem;
  }

  /* Arrow for links */
  .arrow {
    transition: transform 0.15s ease;
  }

  .btn:hover .arrow,
  a:hover .arrow {
    transform: translateX(2px);
  }

  /* ===== GRADIENT TEXT ===== */
  .gradient-text {
    background: linear-gradient(135deg, var(--color-blue) 0%, var(--color-blue-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ===== LABEL TAG ===== */
  .label-tag {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-blue);
    background: rgba(15, 15, 189, 0.08);
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1rem;
  }

  /* ===== SPLIT ROWS ===== */
  .split-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .split-row.reverse .split-image {
    order: -1;
  }

  .split-text h2 {
    font-size: 2rem;
    font-weight: 900;
    color: var(--color-dark);
    line-height: 1.15;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .split-desc {
    font-size: 1rem;
    color: var(--color-gray-500);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .split-image {
    overflow: hidden;
    border-radius: 15px;
    box-shadow: 0 10px 40px rgba(11, 34, 57, 0.1);
    max-height: 420px;
  }

  .split-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 15px;
    display: block;
  }

  .split-cta-text {
    font-size: 1rem;
    color: var(--color-dark);
    margin-top: 0.5rem;
  }

  /* ===== STAT CHIPS ===== */
  .stat-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .stat-chip {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    flex: 1;
  }

  .stat-chip-value {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-blue);
    line-height: 1;
    margin-bottom: 0.25rem;
    letter-spacing: -0.02em;
  }

  .stat-chip-label {
    font-size: 0.75rem;
    color: var(--color-gray-500);
    line-height: 1.4;
  }

  /* ===== CHECK LIST ===== */
  .check-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .check-list li {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }

  .check-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .check-list strong {
    display: block;
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.2rem;
  }

  .check-list span {
    display: block;
    font-size: 0.875rem;
    color: var(--color-gray-500);
    line-height: 1.6;
  }

  /* ===== SECTION TITLES ===== */
  .section-title {
    font-size: 2.25rem;
    font-weight: 900;
    color: var(--color-dark);
    line-height: 1.1;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    text-align: center;
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--color-gray-500);
    line-height: 1.7;
    text-align: center;
    max-width: 540px;
    margin: 0 auto 3rem;
  }

  /* ===== CARD GRID ===== */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .card-grid.cols-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .card-grid.cols-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 15px;
    padding: 2rem;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .card:hover {
    box-shadow: 0 10px 40px rgba(11, 34, 57, 0.1);
    transform: translateY(-4px);
  }

  .card-metric {
    display: block;
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--color-blue) 0%, var(--color-blue-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card h3 {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.5rem;
  }

  .card p {
    font-size: 0.8125rem;
    color: var(--color-gray-500);
    line-height: 1.6;
  }

  /* ===== PARTNERS ===== */
  .partners-label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gray-500);
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .partner-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .partner-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-gray-500);
  }

  .partner-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-gray-300);
  }

  /* ===== BIO CARD ===== */
  .bio-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 15px;
    padding: 2.5rem 2rem;
    text-align: center;
    box-shadow: 0 10px 40px rgba(11, 34, 57, 0.08);
  }

  .bio-avatar {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto 1.25rem;
    border: 3px solid var(--color-gray-100);
  }

  .bio-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bio-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.25rem;
  }

  .bio-role {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-blue);
    margin-bottom: 1rem;
  }

  .bio-desc {
    font-size: 0.875rem;
    color: var(--color-gray-500);
    line-height: 1.6;
  }

  /* ===== CTA SECTION ===== */
  .cta-section {
    background: linear-gradient(135deg, var(--color-blue) 0%, #1a2dd4 50%, var(--color-blue-light) 100%);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-section h2 {
    font-size: 2.25rem;
    font-weight: 900;
    color: var(--color-white);
    line-height: 1.1;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .cta-section p {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 2rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-outline-white {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    border-radius: 100px;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    font-family: var(--font-sans);
    background: transparent;
    color: var(--color-white);
    border: 2px solid rgba(255, 255, 255, 0.3);
    transition: all 0.2s ease;
  }

